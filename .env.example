# Neon Database Configuration
# Get your connection string from your Neon dashboard
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT Secret (generate a random string: openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-here"

# Google Gemini API Configuration
# Get your API key from https://aistudio.google.com/
# This is used by the backend server only (NOT exposed to frontend)
GEMINI_API_KEY="your-gemini-api-key-here"

# Backend Server Configuration
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Frontend Configuration (Vite)
# API URL for the frontend to connect to the backend
# Leave empty for Vercel deployment (API routes are same-origin)
# Set to http://localhost:3001 for local development
VITE_API_URL="http://localhost:3001"
